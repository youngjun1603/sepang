# 세팡 백엔드 환경변수 — 실제 .env 파일로 복사 후 값 채우기
# cp .env.example .env

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase 대시보드 → Settings → API 에서 확인
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=       # 서버 전용 (절대 프론트에 노출 금지)

# ── Database (Supabase Transaction Pooler) ────────────────────────────────────
# Supabase 대시보드 → Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_USE_LONG_RANDOM_SECRET

# ── Firebase FCM (점주 앱 푸시) ───────────────────────────────────────────────
FCM_SERVER_KEY=

# ── Web Push VAPID (고객 PWA 푸시) ────────────────────────────────────────────
# 키 생성: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key); print(v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# ── 카카오 Maps (주소 → 위경도) ───────────────────────────────────────────────
# https://developers.kakao.com → REST API 키
KAKAO_MAP_REST_API_KEY=

# ── 네이버 클라우드 SENS (SMS) ─────────────────────────────────────────────────
NAVER_SENS_SERVICE_ID=
NAVER_SENS_ACCESS_KEY=
NAVER_SENS_SECRET_KEY=
NAVER_SENS_SENDER=010-XXXX-XXXX

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
