# ============================================================
# м„ёнҢЎ нҷҳкІҪліҖмҲҳ н…ңн”ҢлҰҝ вҖ” мӢӨм ң к°’мңјлЎң көҗмІҙ нӣ„ .envлЎң м ҖмһҘ
# м ҲлҢҖ Gitм—җ м»Өл°Ӣн•ҳм§Җ л§Ҳм„ёмҡ”
# ============================================================

# Database
DATABASE_URL=postgresql+asyncpg://sepang:YOUR_PASSWORD@localhost:5432/sepang
POSTGRES_PASSWORD=YOUR_SECURE_DB_PASSWORD

# Redis
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# JWT
JWT_SECRET=your-256-bit-secret-minimum-32-chars

# AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
S3_BUCKET=sepang-photos-production

# Firebase (FCM)
FCM_SERVER_KEY=your-fcm-server-key

# м№ҙм№ҙмҳӨ м•ҢлҰјнҶЎ
KAKAO_APP_KEY=your-kakao-app-key
KAKAO_SECRET_KEY=your-kakao-secret-key
KAKAO_SENDER_KEY=your-kakao-sender-key

# м•ұ м„Өм •
ENVIRONMENT=production
DEBUG=false
CORS_ORIGINS=["https://sepang.kr","https://partner.sepang.kr"]

# Next.js (н”„лЎ нҠём—”л“ң)
NEXT_PUBLIC_API_URL=https://api.sepang.kr
NEXT_PUBLIC_WS_URL=wss://api.sepang.kr
